{
  "eslint.packageManager": "yarn",
  "eslint.autoFixOnSave": true,

  "prettier.tslintIntegration": true,
  "prettier.eslintIntegration": true,
  "prettier.disableSuccessMessage": true,

  "suggest.noselect": false,
  "snippets.priority": 200,
  "snippets.extends": {
    "typescript": ["javascript"]
  },

  "coc.preferences.currentFunctionSymbolAutoUpdate": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "typescript",
    "graphql",
    "html",
    "json",
    "css",
    "scss",
    "dart"
  ],

  "diagnostic.infoSign": "•",
  "diagnostic.hintSign": "•",
  "diagnostic.warningSign": "•",
  "diagnostic.errorSign": "•",
  "diagnostic.enable": true,
  "diagnostic.refreshOnInsertMode": true,

  "flutter.lsp.initialization.closingLabels": true,
  "flutter.provider.hot-reload": true,
  "flutter.provider.enableSnippet": true,

  "explorer.icon.expanded": "▾",
  "explorer.icon.enableNerdfont": true,
  "explorer.quitOnOpen": true,
  "explorer.openAction.strategy": "sourceWindow",
  "explorer.keyMappings": {
    "i": "unmap",

    "k": "nodePrev",
    "j": "nodeNext",
    "gk": "expandablePrev",
    "gj": "expandableNext",

    "*": "toggleSelection",
    "<tab>": "actionMenu",

    "h": "collapse",
    "l": ["expandable?", "expand", "open"],
    "J": ["toggleSelection", "nodeNext"],
    "K": ["toggleSelection", "nodePrev"],
    "gl": "expandRecursive",
    "gh": "collapseRecursive",
    "o": "expandOrCollapse",
    "<cr>": ["expandable?", "cd", "open"],
    "e": "open",
    "s": "open:split",
    "S": "open:split:plain",
    "E": "open:vsplit",
    "t": "open:tab",
    "<bs>": "gotoParent",
    "gp": "preview:labeling",

    "y": "copyFilepath",
    "Y": "copyFilename",
    "c": "copyFile",
    "x": "cutFile",
    "p": "pasteFile",
    "d": "delete",
    "D": "deleteForever",

    "a": "addFile",
    "A": "addDirectory",
    "r": "rename",

    ".": "toggleHidden",
    "R": "refresh",

    "?": "help",
    "q": "quit",
    "<esc>": "esc",
    "X": "systemExecute",
    "gd": "listDrive",

    "f": "search",
    "F": "searchRecursive",

    "gf": "gotoSource:file",
    "gb": "gotoSource:buffer",

    "[[": "sourcePrev",
    "]]": "sourceNext",

    "[d": "diagnosticPrev",
    "]d": "diagnosticNext",

    "[c": "gitPrev",
    "]c": "gitNext",
    "<<": "gitStage",
    ">>": "gitUnstage"
  }
}
